# CDCP フロントエンド 開発環境設定
# .env.development.local にコピーして Auth0 実値を設定してください

# Auth0 設定（manage.auth0.com でテナント作成後に設定）
VITE_AUTH0_DOMAIN=dev-cdcp.auth0.com
VITE_AUTH0_CLIENT_ID=your_dev_client_id
VITE_AUTH0_AUDIENCE=https://api.cdcp.dev

# API エンドポイント
VITE_API_URL=http://localhost:3000/api/v1

# アプリ設定
VITE_APP_TITLE=CDCP - 建設DXプラットフォーム
VITE_APP_VERSION=1.0.0

# フィーチャーフラグ
VITE_ENABLE_MAP=true
VITE_ENABLE_PWA_OFFLINE=false
